    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.13",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.0.0",
