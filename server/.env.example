# Required — app will refuse to start without these
DATABASE_URL=postgresql://user:password@host:5432/chatbridge
ANTHROPIC_API_KEY=sk-ant-api03-...
JWT_SECRET=change-me-to-a-random-32-plus-character-string

# Optional — demo apps work without these (mock data / graceful degradation)
WEATHER_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Set automatically by Railway — override locally if needed
PORT=3000

# OAuth redirect base URL — set to your Railway service URL in production
# e.g. https://chatbridge.up.railway.app
CLIENT_URL=http://localhost:5173
